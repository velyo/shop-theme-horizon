                        "custom_liquid_jfyAWU": {
                            "type": "custom-liquid",
                            "name": "Size calculator",
                            "settings": {
                                "custom_liquid": "<style>\n.size-calculator { max-width:680px; padding:16px; border:1px solid #e4e4e4; background:#fff; border-radius:8px; font-family:inherit; }\n.size-calculator h3 { margin:0 0 12px; font-size:18px; }\n.size-calculator .inputs { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:12px; }\n.size-calculator .inputs .field { flex:1 1 150px; }\n.size-calculator label { display:block; font-size:13px; margin-bottom:6px; color:#333; }\n.size-calculator input[type=\"number\"] { width:100%; padding:8px; border:1px solid #ccc; border-radius:6px; font-size:14px; }\n.size-calculator .actions { display:flex; gap:8px; align-items:center; margin-bottom:12px; }\n.size-calculator button { background:#111; color:#fff; border:none; padding:10px 14px; border-radius:6px; cursor:pointer; }\n.size-calculator .result { padding:12px; border-radius:6px; background:#f7f9fb; border:1px solid #e6eef6; color:#062; font-weight:600; display:none; }\n.size-calculator .note { margin-top:8px; font-size:13px; color:#666; }\n.size-calculator .size-breakdown { margin-top:8px; font-size:14px; color:#222; }\n.size-calculator .tips-toggle { margin-left:auto; font-size:13px; color:#0073e6; cursor:pointer; text-decoration:underline; }\n.size-calculator .tips { margin:12px 0; padding:12px; background:#fcfcfd; border:1px solid #eef3fb; border-radius:6px; display:none; font-size:14px; color:#222; }\n.size-calculator .tips ul { margin:8px 0 0 1.1em; }\n@media (max-width:520px){ .size-calculator .inputs { flex-direction:column; } .size-calculator .tips-toggle { display:block; margin-top:8px; } }\n</style>\n\n<div class=\"size-calculator\" id=\"sizeCalculator\">\n  <h3>Калкулатор на размери (EU)</h3>\n\n  <div>\n    <span class=\"tips-toggle\" id=\"toggleTips\">Съвети за измерване ▾</span>\n  </div>\n\n  <div class=\"tips\" id=\"measureTips\" aria-hidden=\"true\">\n    <strong>Съвети при измерване:</strong>\n    <ul>\n      <li><strong>Бюст:</strong> измерете най‑пълната част на гърдите, хоризонтално.</li>\n      <li><strong>Талия:</strong> измерете най‑тясната част на торса.</li>\n      <li><strong>Ханш:</strong> измерете най‑пълната част на ханша/бедрата.</li>\n      <li>Дръжте мерната лента плътно, но не притискащо; стойностите са ориентировъчни — при междинни размери вземете по‑големия за комфорт.</li>\n    </ul>\n  </div>\n\n  <div class=\"inputs\">\n    <div class=\"field\">\n      <label for=\"measureBust\">Бюст (cm)</label>\n      <input id=\"measureBust\" type=\"number\" min=\"30\" step=\"0.5\" placeholder=\"напр. 90\">\n    </div>\n    <div class=\"field\">\n      <label for=\"measureWaist\">Талия (cm)</label>\n      <input id=\"measureWaist\" type=\"number\" min=\"40\" step=\"0.5\" placeholder=\"напр. 70\">\n    </div>\n    <div class=\"field\">\n      <label for=\"measureHips\">Ханш (cm)</label>\n      <input id=\"measureHips\" type=\"number\" min=\"60\" step=\"0.5\" placeholder=\"напр. 96\">\n    </div>\n  </div>\n\n  <div class=\"actions\">\n    <button id=\"calcSizeBtn\" type=\"button\">Изчисли размер</button>\n    <div id=\"calcClear\" style=\"cursor:pointer;color:#0073e6;text-decoration:underline;\">Изчисти</div>\n  </div>\n\n  <div id=\"calcResult\" class=\"result\"></div>\n  <div id=\"calcNote\" class=\"note\"></div>\n  <div id=\"sizeDetails\" class=\"size-breakdown\"></div>\n</div>\n\n<script>\n(function(){\n  var sizeTable = [\n    { name: \"XXS (EU 32)\", bust:[76,80], waist:[58,62], hips:[82,86] },\n    { name: \"XS  (EU 34)\", bust:[81,84], waist:[63,66], hips:[87,90] },\n    { name: \"S   (EU 36)\", bust:[85,88], waist:[67,70], hips:[91,94] },\n    { name: \"M   (EU 38)\", bust:[89,92], waist:[71,74], hips:[95,98] },\n    { name: \"L   (EU 40)\", bust:[93,96], waist:[75,78], hips:[99,102] },\n    { name: \"XL  (EU 42)\", bust:[97,100], waist:[79,82], hips:[103,106] },\n    { name: \"XXL (EU 44)\", bust:[101,104], waist:[83,86], hips:[107,110] }\n  ];\n\n  var elBust = document.getElementById('measureBust');\n  var elWaist = document.getElementById('measureWaist');\n  var elHips = document.getElementById('measureHips');\n  var btn = document.getElementById('calcSizeBtn');\n  var res = document.getElementById('calcResult');\n  var note = document.getElementById('calcNote');\n  var details = document.getElementById('sizeDetails');\n  var clear = document.getElementById('calcClear');\n\n  var tipsToggle = document.getElementById('toggleTips');\n  var tipsBox = document.getElementById('measureTips');\n  tipsToggle.addEventListener('click', function(){\n    var shown = tipsBox.style.display === 'block';\n    tipsBox.style.display = shown ? 'none' : 'block';\n    tipsBox.setAttribute('aria-hidden', shown ? 'true' : 'false');\n    tipsToggle.textContent = shown ? 'Съвети за измерване ▾' : 'Съвети за измерване ▴';\n  });\n\n  function inRange(value, range){ return value >= range[0] && value <= range[1]; }\n\n  function closestSize(b, w, h){\n    var best = null; var bestScore = Infinity;\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      var midB = (s.bust[0]+s.bust[1])/2;\n      var midW = (s.waist[0]+s.waist[1])/2;\n      var midH = (s.hips[0]+s.hips[1])/2;\n      var score = Math.pow(b-midB,2) + Math.pow(w-midW,2) + Math.pow(h-midH,2);\n      if(score < bestScore){ bestScore = score; best = s; }\n    }\n    return best;\n  }\n\n  function findExact(b, w, h){\n    var matches = [];\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      if(inRange(b, s.bust) && inRange(w, s.waist) && inRange(h, s.hips)){\n        matches.push(s);\n      }\n    }\n    return matches;\n  }\n\n  function formatRange(r){ return r[0] + \"–\" + r[1] + \" cm\"; }\n\n  btn.addEventListener('click', function(){\n    var b = parseFloat(elBust.value);\n    var w = parseFloat(elWaist.value);\n    var h = parseFloat(elHips.value);\n    res.style.display = 'none';\n    note.textContent = '';\n    details.innerHTML = '';\n\n    if(isNaN(b) || isNaN(w) || isNaN(h)){\n      res.style.display = 'block';\n      res.style.color = '#b00';\n      res.textContent = 'Моля въведете стойности за бюст, талия и ханш (в см).';\n      return;\n    }\n\n    var exact = findExact(b,w,h);\n    if(exact.length > 0){\n      var chosen = exact[0];\n      res.style.display = 'block';\n      res.style.color = '#062';\n      res.textContent = 'Препоръчан размер: ' + chosen.name;\n      note.textContent = 'Впадате в диапазоните за този размер.';\n      details.innerHTML = '<strong>Диапазони за ' + chosen.name + ':</strong><br>' +\n        'Бюст: ' + formatRange(chosen.bust) + '<br>' +\n        'Талия: ' + formatRange(chosen.waist) + '<br>' +\n        'Ханш: ' + formatRange(chosen.hips);\n    } else {\n      var nearest = closestSize(b,w,h);\n      res.style.display = 'block';\n      res.style.color = '#e65d00';\n      res.textContent = 'Няма точен съвпад; най-близък размер: ' + nearest.name;\n      note.textContent = 'Препоръка: помислете дали да вземете този размер или близкия (в зависимост от желанията за прибиране/комфорт).';\n      details.innerHTML = '<strong>Диапазони за ' + nearest.name + ':</strong><br>' +\n        'Бюст: ' + formatRange(nearest.bust) + '<br>' +\n        'Талия: ' + formatRange(nearest.waist) + '<br>' +\n        'Ханш: ' + formatRange(nearest.hips) +\n        '<br><br><em>Въведени стойности:</em><br>Бюст: ' + b + ' cm, Талия: ' + w + ' cm, Ханш: ' + h + ' cm';\n    }\n  });\n\n  clear.addEventListener('click', function(){\n    elBust.value = '';\n    elWaist.value = '';\n    elHips.value = '';\n    res.style.display = 'none';\n    note.textContent = '';\n    details.innerHTML = '';\n  });\n\n  [elBust, elWaist, elHips].forEach(function(el){\n    el.addEventListener('keydown', function(e){ if(e.key === 'Enter'){ btn.click(); } });\n  });\n})();\n</script>"
                            },
                            "blocks": {}
                        },
