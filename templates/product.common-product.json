                        "custom_liquid_RXbicL": {
                            "type": "custom-liquid",
                            "name": "Specs",
                            "settings": {
                                "custom_liquid": "<div class=\"product-specs\">\n  {% if product.metafields.custom.specs_text and product.metafields.custom.specs_text != '' %}\n    <b>Характеристики:</b>\n    <div class=\"specs-richtext\">{{ product.metafields.custom.specs_text | metafield_tag }}</div>\n  {% endif %}  \n  {% if product.metafields.custom.wearing_style and product.metafields.custom.wearing_style != '' %}\n    <b>Начин на носене:</b>\n    <div class=\"specs-richtext\">{{ product.metafields.custom.wearing_style | metafield_tag }}</div>\n  {% endif %}\n  {% if product.metafields.custom.choice_advices and product.metafields.custom.choice_advices != '' %}\n    <b>Съвети за избор:</b>\n    <div class=\"specs-richtext\">{{ product.metafields.custom.choice_advices | metafield_tag }}</div>\n  {% endif %}\n  {% if product.metafields.custom.care_items and product.metafields.custom.care_items != '' %}\n    <b>Съвети за поддръжка:</b>\n    <div class=\"specs-richtext\">{{ product.metafields.custom.care_items | metafield_tag }}</div>\n  {% endif %}  \n  {% if product.metafields.custom.materials and product.metafields.custom.materials != '' %}\n    <div class=\"materials\">\n      <b>Състав:</b> {{ product.metafields.custom.materials | newline_to_br }}\n    </div>\n  {% endif %}\n  {% if product.metafields.custom.producer and product.metafields.custom.producer != '' %}\n    <div class=\"producer\">\n      <b>Производител:</b> {{ product.metafields.custom.producer | newline_to_br }}\n    </div>\n  {% endif %}\n  {% if product.metafields.custom.country and product.metafields.custom.country != '' %}\n    <div class=\"country\">\n      <b>Страна:</b> {{ product.metafields.custom.country | newline_to_br }}\n    </div>\n  {% endif %}\n</div>\n\n<style>\n  .product-specs {\n    margin-top: 1rem;\n    padding: 1rem;\n    background-color: #f9f9f9;\n    border: 1px solid #ddd;\n  }\n\n  .product-specs .specs-richtext ul {\n    margin-top: 0.5rem;\n    margin-bottom: 0.75rem;\n    padding-left: 1.25rem;\n  }\n\n  .product-specs .specs-richtext p {\n    margin-top: 0.5rem;\n    margin-bottom: 0.75rem;\n  }\n</style>"
