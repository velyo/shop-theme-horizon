            "custom_liquid_jefqmQ": {
              "type": "custom-liquid",
              "name": "Size calculator",
              "settings": {
                "custom_liquid": "<style>\n.boxer-calculator { max-width:680px; padding:16px; border:1px solid #e4e4e4; background:#fff; border-radius:8px; font-family:inherit; }\n.boxer-calculator h3 { margin:0 0 12px; font-size:18px; display:flex; align-items:center; }\n.boxer-calculator .tips-toggle { margin-left:auto; font-size:13px; color:#0073e6; cursor:pointer; text-decoration:underline; }\n.boxer-calculator .grid { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; align-items:center; }\n.boxer-calculator .field { flex:0 1 auto; }\n.boxer-calculator label { display:block; font-size:13px; margin-bottom:4px; color:#333; min-width:126px; }\n.boxer-calculator input[type=\"number\"] { width:100%; max-width:160px; height:40px; padding:6px 8px; border:1px solid #ccc; border-radius:6px; font-size:14px; box-sizing:border-box; }\n.boxer-calculator .actions { display:flex; gap:8px; align-items:center; margin-bottom:12px; }\n.boxer-calculator button { background:#111; color:#fff; border:none; padding:10px 14px; border-radius:6px; cursor:pointer; }\n.boxer-calculator .result { padding:12px; border-radius:6px; background:#f7f9fb; border:1px solid #e6eef6; color:#062; font-weight:600; display:none; }\n.boxer-calculator .note { margin-top:8px; font-size:13px; color:#666; }\n.boxer-calculator .tips { margin:12px 0; padding:12px; background:#fcfcfd; border:1px solid #eef3fb; border-radius:6px; display:none; font-size:14px; color:#222; }\n@media (max-width:520px){ .boxer-calculator .grid { flex-direction:column; } .boxer-calculator .field { max-width:100%; } }\n</style>\n\n<div class=\"boxer-calculator\" id=\"boxerCalc\">\n  <h3>Калкулатор за размер боксерки (EU)</h3>\n\n  <div>\n    <span class=\"tips-toggle\" id=\"toggleBoxerTips\">Съвети за измерване ▾</span>\n  </div>\n\n  <div class=\"tips\" id=\"boxerTips\" aria-hidden=\"true\">\n    <strong>Съвети при измерване</strong>\n    <ul>\n      <li><strong>Талия:</strong> измерете най-тясната част на талията или там, където носите боксерките (см).</li>\n      <li><strong>Ханш (опция):</strong> измерете най-пълната част на ханша, ако искате по-точно прилепване за по-широки модели.</li>\n      <li>Дръжте лентата плътно, но не притискащо. При междинни стойности изберете по-големия размер за комфорт.</li>\n    </ul>\n  </div>\n\n  <div class=\"grid\">\n    <div class=\"field\">\n      <label for=\"boxerWaist\">Талия (cm)</label>\n      <input id=\"boxerWaist\" type=\"number\" min=\"50\" step=\"0.5\" placeholder=\"напр. 88\">\n    </div>\n    <div class=\"field\">\n      <label for=\"boxerHips\">Ханш (см) — опция</label>\n      <input id=\"boxerHips\" type=\"number\" min=\"70\" step=\"0.5\" placeholder=\"напр. 98\">\n    </div>\n  </div>\n\n  <div class=\"actions\">\n    <button id=\"calcBoxer\">Изчисли размер</button>\n    <div id=\"clearBoxer\" style=\"cursor:pointer;color:#0073e6;text-decoration:underline;\">Изчисти</div>\n  </div>\n\n  <div id=\"boxerResult\" class=\"result\"></div>\n  <div id=\"boxerNote\" class=\"note\"></div>\n</div>\n\n<script>\n(function(){\n  var sizeTable = [\n    { name: \"S (EU 46)\", waist:[74,78], hips:[88,92] },\n    { name: \"M (EU 48)\", waist:[79,83], hips:[93,97] },\n    { name: \"L (EU 50)\", waist:[84,88], hips:[98,102] },\n    { name: \"XL (EU 52)\", waist:[89,93], hips:[103,107] },\n    { name: \"XXL (EU 54)\", waist:[94,99], hips:[108,113] }\n  ];\n\n  var elWaist = document.getElementById('boxerWaist');\n  var elHips = document.getElementById('boxerHips');\n  var btn = document.getElementById('calcBoxer');\n  var clr = document.getElementById('clearBoxer');\n  var out = document.getElementById('boxerResult');\n  var note = document.getElementById('boxerNote');\n\n  var tipsToggle = document.getElementById('toggleBoxerTips');\n  var tipsBox = document.getElementById('boxerTips');\n  tipsToggle.addEventListener('click', function(){\n    var shown = tipsBox.style.display === 'block';\n    tipsBox.style.display = shown ? 'none' : 'block';\n    tipsBox.setAttribute('aria-hidden', shown ? 'true' : 'false');\n    tipsToggle.textContent = shown ? 'Съвети за измерване ▾' : 'Съвети за измерване ▴';\n  });\n\n  function inRange(value, range){ return value >= range[0] && value <= range[1]; }\n\n  function findExact(waist, hips){\n    var matches = [];\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      var waistMatch = inRange(waist, s.waist);\n      var hipsMatch = true;\n      if(!isNaN(hips) && hips !== null && hips !== '') hipsMatch = inRange(hips, s.hips);\n      if(waistMatch && hipsMatch) matches.push(s);\n    }\n    return matches;\n  }\n\n  function closestByWaist(waist){\n    var best = null; var bestDiff = Infinity;\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      var mid = (s.waist[0]+s.waist[1])/2;\n      var diff = Math.abs(waist - mid);\n      if(diff < bestDiff){ bestDiff = diff; best = s; }\n    }\n    return best;\n  }\n\n  function formatRange(r){ return r[0] + \"–\" + r[1] + \" cm\"; }\n\n  btn.addEventListener('click', function(){\n    out.style.display = 'none';\n    note.textContent = '';\n    var waist = parseFloat(elWaist.value);\n    var hips = parseFloat(elHips.value);\n\n    if(isNaN(waist) || waist <= 0){\n      out.style.display = 'block';\n      out.style.color = '#b00';\n      out.textContent = 'Въведете валидна стойност за талия (в см).';\n      return;\n    }\n\n    var exact = findExact(waist, hips);\n    if(exact.length > 0){\n      var chosen = exact[0];\n      out.style.display = 'block';\n      out.style.color = '#062';\n      out.textContent = 'Препоръчан размер: ' + chosen.name;\n      note.textContent = 'Диапазон талия: ' + formatRange(chosen.waist) + (hips ? '; ханш: ' + formatRange(chosen.hips) : '');\n    } else {\n      var nearest = closestByWaist(waist);\n      out.style.display = 'block';\n      out.style.color = '#e65d00';\n      out.textContent = 'Няма точен съвпад; най-близък размер: ' + nearest.name;\n      note.textContent = 'Диапазон талия: ' + formatRange(nearest.waist) + (hips ? '; ханш: ' + formatRange(nearest.hips) : '') + '. Ако предпочитате по-широко прилягане, изберете следващия размер.';\n    }\n  });\n\n  clr.addEventListener('click', function(){\n    elWaist.value = '';\n    elHips.value = '';\n    out.style.display = 'none';\n    note.textContent = '';\n  });\n\n  [elWaist, elHips].forEach(function(el){\n    el.addEventListener('keydown', function(e){ if(e.key === 'Enter') btn.click(); });\n  });\n})();\n</script>"
              },
