            "custom_liquid_pPFzPE": {
              "type": "custom-liquid",
              "name": "Спецификация",
              "settings": {
                "custom_liquid": "<div class=\"product-specs\">\n  {% if product.metafields.custom.specs_text and product.metafields.custom.specs_text != '' %}\n    <b>Характеристики:</b>\n    <ul>\n      {% assign text_values = product.metafields.custom.specs_text | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}</li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    </ul>\n  {% endif %}  \n  {% if product.metafields.custom.care_items and product.metafields.custom.care_items != '' %}\n    <b>Съвети за поддръжка:</b>\n    <ul>\n      {% assign text_values = product.metafields.custom.care_items | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}</li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    </ul>\n  {% endif %}\n  {% if product.metafields.custom.choice_advices and product.metafields.custom.choice_advices != '' %}\n    <b>Съвети за избор:</b>\n    <ul>\n      {% assign text_values = product.metafields.custom.choice_advices | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}</li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    </ul>\n  {% endif %}\n  {% if product.metafields.custom.materials and product.metafields.custom.materials != '' %}\n    <div class=\"materials\">\n      <b>Състав:</b> {{ product.metafields.custom.materials | newline_to_br }}\n    </div>\n  {% endif %}\n  {% if product.metafields.custom.producer and product.metafields.custom.producer != '' %}\n    <div class=\"producer\">\n      <b>Производител:</b> {{ product.metafields.custom.producer | newline_to_br }}\n    </div>\n  {% endif %}\n  {% if product.metafields.custom.country and product.metafields.custom.country != '' %}\n    <div class=\"country\">\n      <b>Страна:</b> {{ product.metafields.custom.country | newline_to_br }}\n    </div>\n  {% endif %}\n</div>\n\n<style>\n  .product-specs {\n    margin-top: 1rem;\n    padding: 1rem;\n    background-color: #f9f9f9;\n    border: 1px solid #ddd;\n  }\n</style>"
