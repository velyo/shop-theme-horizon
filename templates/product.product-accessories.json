                        "padding-block-start": 0,
                        "padding-block-end": 0,
                        "padding-inline-start": 0,
                        "padding-inline-end": 0
                      },
                      "blocks": {}
                    }
                  },
                  "block_order": [
                    "text_P336YL"
                  ]
                },
                "accordion_row_Nmp8iR": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "ВАЖНО",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 24
                  },
                  "blocks": {
                    "text_ENFf9p": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Като вносители, ние подлагаме всяка дреха, която пристига при нас, на няколко щателни проверки за качество. За удобство и точност продуктите са допълнително оразмерени спрямо таблицата с размери, посочена в сайта. Обувките и аксесоарите също преминават строг контрол за качество при постъпване.</p><p>Препоръчителни инструкции за поддръжка на дрехи:</p><ul><li>Ръчно пране или пране на ниска температура (до 30°C).</li><li>Не използвайте сушилня за допълнителна обработка.</li></ul><p>Препоръчителни инструкции за поддръжка на обувки и аксесоари:</p><ul><li>Почистване на ръка; избягвайте силни почистващи препарати.</li><li>Не ператe в пералня и не оставяйте на пряка слънчева светлина.</li></ul><p>С всяка поръчка получавате гаранцията на Benny Boutique, че ще получите пратката си в перфектен вид, плюс:</p><ul><li>Бърза доставка</li><li>Тест и преглед преди изпращане</li><li>Безплатна доставка за поръчки над 50€ / 97.79 лв</li><li>Безплатна замяна за артикули на стойност над 35 € / 68.45 лв<br/><br/></li></ul>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "font": "var(--font-body--family)",
                        "font_size": "1rem",
                        "line_height": "normal",
