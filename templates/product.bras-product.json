                        "custom_liquid_XaLk66": {
                            "type": "custom-liquid",
                            "name": "Size calculator",
                            "settings": {
                                "custom_liquid": "<style>\n.bra-calculator { max-width:680px; padding:16px; border:1px solid #e4e4e4; background:#fff; border-radius:8px; font-family:inherit; }\n.bra-calculator h3 { margin:0 0 12px; font-size:18px; display:flex; align-items:center; }\n.bra-calculator .tips-toggle { margin-left:0; margin-top:8px; font-size:13px; color:#0073e6; cursor:pointer; text-decoration:underline; display:block; }\n.bra-calculator .grid { display:flex; gap:0px; flex-wrap:wrap; margin-bottom:12px; }\n.bra-calculator .field { flex:0 1 auto; }\n.bra-calculator label { display:block; font-size:13px; margin-bottom:6px; color:#333; }\n.bra-calculator input[type=\"number\"] { width:100%; padding:6px 8px; border:1px solid #ccc; border-radius:6px; font-size:14px; line-height:1; height:32px; }\n.bra-calculator .actions { display:flex; gap:8px; align-items:center; margin-bottom:12px; }\n.bra-calculator button { background:#111; color:#fff; border:none; padding:10px 14px; border-radius:6px; cursor:pointer; }\n.bra-calculator .result { padding:12px; border-radius:6px; background:#f7f9fb; border:1px solid #e6eef6; color:#062; font-weight:600; display:none; }\n.bra-calculator .note { margin-top:8px; font-size:13px; color:#666; }\n.bra-calculator .tips { margin:12px 0; margin-bottom:6px;padding:12px; background:#fcfcfd; border:1px solid #eef3fb; border-radius:6px; display:none; font-size:14px; color:#222; }\n.bra-calculator .tips ul { margin:8px 0 0 1.1em; }\n@media (max-width:520px){ .bra-calculator .grid { flex-direction:column; } .bra-calculator .tips-toggle { display:block; margin-top:8px; } }\n</style>\n\n<div class=\"bra-calculator\" id=\"braCalc\">\n  <h3>Калкулатор за размер сутиен (EU)</h3>\n\n  <div>\n    <span class=\"tips-toggle\" id=\"toggleBraTips\">Съвети за измерване ▾</span>\n  </div>\n\n  <div class=\"tips\" id=\"braTips\" aria-hidden=\"true\">\n    <strong>Съвети при измерване</strong>\n    <ul>\n      <li><strong>Обиколка под гърдите:</strong> измерете точно под гърдите, хоризонтално, с плътна но не притискаща лента.</li>\n      <li><strong>Обиколка на гърдите:</strong> измерете най‑пълната част на гърдите, хоризонтално.</li>\n      <li>Ако сте между два размера на лентата, изберете по‑голямата стойност и регулирайте чашката според комфорта.</li>\n    </ul>\n  </div>\n\n  <div class=\"grid\">\n    <div class=\"field\">\n      <label for=\"underband\">Обиколка под гърдите (см)</label>\n      <input id=\"underband\" type=\"number\" min=\"50\" step=\"0.5\" placeholder=\"напр. 75\">\n    </div>\n    <div class=\"field\">\n      <label for=\"bust\">Обиколка на гърдите (см)</label>\n      <input id=\"bust\" type=\"number\" min=\"60\" step=\"0.5\" placeholder=\"напр. 92\">\n    </div>\n  </div>\n\n  <div class=\"actions\">\n    <button id=\"calcBra\">Изчисли размер</button>\n    <div id=\"clearBra\" style=\"cursor:pointer;color:#0073e6;text-decoration:underline;\">Изчисти</div>\n  </div>\n\n  <div id=\"braResult\" class=\"result\"></div>\n  <div id=\"braNote\" class=\"note\"></div>\n</div>\n\n<script>\n(function(){\n  var elUnder = document.getElementById('underband');\n  var elBust = document.getElementById('bust');\n  var btn = document.getElementById('calcBra');\n  var clr = document.getElementById('clearBra');\n  var out = document.getElementById('braResult');\n  var note = document.getElementById('braNote');\n\n  var tipsToggle = document.getElementById('toggleBraTips');\n  var tipsBox = document.getElementById('braTips');\n  tipsToggle.addEventListener('click', function(){\n    var shown = tipsBox.style.display === 'block';\n    tipsBox.style.display = shown ? 'none' : 'block';\n    tipsBox.setAttribute('aria-hidden', shown ? 'true' : 'false');\n    tipsToggle.textContent = shown ? 'Съвети за измерване ▾' : 'Съвети за измерване ▴';\n  });\n\n  var cupMap = [\n    { maxDiff: 9,  cup: \"AA\" },\n    { maxDiff: 11, cup: \"A\" },\n    { maxDiff: 13, cup: \"B\" },\n    { maxDiff: 15, cup: \"C\" },\n    { maxDiff: 17, cup: \"D\" },\n    { maxDiff: 19, cup: \"E\" },\n    { maxDiff: 21, cup: \"F\" },\n    { maxDiff: 999, cup: \"G+\" }\n  ];\n\n  function roundBand(n){\n    var r = Math.round(n/5)*5;\n    if(r < 60) r = 60;\n    return r;\n  }\n\n  function detectCup(diff){\n    for(var i=0;i<cupMap.length;i++){\n      if(diff <= cupMap[i].maxDiff) return cupMap[i].cup;\n    }\n    return \"—\";\n  }\n\n  btn.addEventListener('click', function(){\n    out.style.display = 'none';\n    note.textContent = '';\n    var under = parseFloat(elUnder.value);\n    var bust = parseFloat(elBust.value);\n\n    if(isNaN(under) || isNaN(bust) || under <= 0 || bust <= 0){\n      out.style.display = 'block';\n      out.style.color = '#b00';\n      out.textContent = 'Въведете валидни измервания (см) за подгърдие и гръдна обиколка.';\n      return;\n    }\n\n    var band = roundBand(under);\n    var diff = Math.round((bust - band) * 10) / 10;\n    var cup = detectCup(diff);\n\n    out.style.display = 'block';\n    out.style.color = '#062';\n    out.innerHTML = 'Препоръчителен размер: <strong>' + band + ' ' + cup + '</strong>';\n\n    var noteText = 'Изчислено: обиколка под гърдите ' + under + ' cm → банда ' + band + ' cm; разлика: ' + diff + ' cm.';\n    if(cup === \"G+\") noteText += ' Голяма разлика — помислете за модели с по-голяма чашка.';\n    note.textContent = noteText;\n  });\n\n  clr.addEventListener('click', function(){\n    elUnder.value = '';\n    elBust.value = '';\n    out.style.display = 'none';\n    note.textContent = '';\n  });\n\n  [elUnder, elBust].forEach(function(el){\n    el.addEventListener('keydown', function(e){ if(e.key === 'Enter') btn.click(); });\n  });\n})();\n</script>"
                            },
                            "blocks": {}
                        },
