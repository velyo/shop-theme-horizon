:{"stacking":true,"show_pickup_availability":true,"gift_card_form":true,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"quantity":{"type":"quantity","static":true,"settings":{},"blocks":{}},"add-to-cart":{"type":"add-to-cart","static":true,"settings":{"style_class":"button"},"blocks":{}},"accelerated-checkout":{"type":"accelerated-checkout","static":true,"settings":{},"blocks":{}}},"block_order":[]},"text_aEtTtq":{"type":"text","name":"Product description","settings":{"text":"{{ closest.product.description }}<p><\/p>","width":"100%","max_width":"normal","alignment":"left","type_preset":"custom","font":"var(--font-primary--family)","font_size":"","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"custom_liquid_9JjUCC":{"type":"custom-liquid","name":"Specs","settings":{"custom_liquid":"<div class=\"product-specs\">\n  {% if product.metafields.custom.specs_text and product.metafields.custom.specs_text != '' %}\n    <b>Характеристики:<\/b>\n    <ul>\n      {% assign text_values = product.metafields.custom.specs_text | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}<\/li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    <\/ul>\n  {% endif %}  \n  {% if product.metafields.custom.wearing_style and product.metafields.custom.wearing_style != '' %}\n    <b>Начин на носене:<\/b>\n    <ul>\n      {% assign text_values = product.metafields.custom.wearing_style | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}<\/li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    <\/ul>\n  {% endif %}\n  {% if product.metafields.custom.care_items and product.metafields.custom.care_items != '' %}\n    <b>Съвети за поддръжка:<\/b>\n    <ul>\n      {% assign text_values = product.metafields.custom.care_items | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}<\/li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    <\/ul>\n  {% endif %}\n  {% if product.metafields.custom.choice_advices and product.metafields.custom.choice_advices != '' %}\n    <b>Съвети за избор:<\/b>\n    <ul>\n      {% assign text_values = product.metafields.custom.choice_advices | split: '\"value\":\"' %}\n      {% for value in text_values %}\n        {% if forloop.index > 1 %}\n          {% capture item %}{{ value | split: '\"' | first }}{% endcapture %}\n          {% if item != '' %}\n            <li>{{ item }}<\/li>\n          {% endif %}\n        {% endif %}\n      {% endfor %}\n    <\/ul>\n  {% endif %}\n  {% if product.metafields.custom.materials and product.metafields.custom.materials != '' %}\n    <div class=\"materials\">\n      <b>Състав:<\/b> {{ product.metafields.custom.materials | newline_to_br }}\n    <\/div>\n  {% endif %}\n  {% if product.metafields.custom.producer and product.metafields.custom.producer != '' %}\n    <div class=\"producer\">\n      <b>Производител:<\/b> {{ product.metafields.custom.producer | newline_to_br }}\n    <\/div>\n  {% endif %}\n  {% if product.metafields.custom.country and product.metafields.custom.country != '' %}\n    <div class=\"country\">\n      <b>Страна:<\/b> {{ product.metafields.custom.country | newline_to_br }}\n    <\/div>\n  {% endif %}\n<\/div>\n\n<style>\n  .product-specs {\n    margin-top: 1rem;\n    padding: 1rem;\n    background-color: #f9f9f9;\n    border: 1px solid #ddd;\n  }\n<\/style>"},"blocks":{}},"custom_liquid_bLUC7J":{"type":"custom-liquid","name":"Size calculator","settings":{"custom_liquid":"<style>\n.tights-calculator { max-width:680px; padding:16px; border:1px solid #e4e4e4; background:#fff; border-radius:8px; font-family:inherit; }\n.tights-calculator h3 { margin:0 0 12px; font-size:18px; display:flex; align-items:center; }\n.tights-calculator .tips-toggle { margin-left:auto; font-size:13px; color:#0073e6; cursor:pointer; text-decoration:underline; }\n.tights-calculator .grid { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; align-items:center; }\n.tights-calculator .field { flex:0 1 auto; max-width:220px; margin:0; }\n.tights-calculator label { display:block; font-size:13px; margin-bottom:4px; color:#333; }\n.tights-calculator input[type=\"number\"] { width:100%; height:40px; padding:6px 8px; border:1px solid #ccc; border-radius:6px; font-size:14px; box-sizing:border-box; }\n.tights-calculator .actions { display:flex; gap:8px; align-items:center; margin-bottom:12px; }\n.tights-calculator button { background:#111; color:#fff; border:none; padding:10px 14px; border-radius:6px; cursor:pointer; }\n.tights-calculator .result { padding:12px; border-radius:6px; background:#f7f9fb; border:1px solid #e6eef6; color:#062; font-weight:600; display:none; }\n.tights-calculator .note { margin-top:8px; font-size:13px; color:#666; }\n.tights-calculator .tips { margin:12px 0; padding:12px; background:#fcfcfd; border:1px solid #eef3fb; border-radius:6px; display:none; font-size:14px; color:#222; }\n.tights-calculator .tips ul { margin:8px 0 0 1.1em; }\n@media (max-width:520px){ .tights-calculator .grid { flex-direction:column; } .tights-calculator .field { max-width:100%; } }\n<\/style>\n\n<div class=\"tights-calculator\" id=\"tightsCalc\">\n  <h3>Калкулатор за размер на чорапогащник (Италия)<\/h3>\n\n  <div>\n    <span class=\"tips-toggle\" id=\"toggleTightsTips\">Съвети за измерване ▾<\/span>\n  <\/div>\n\n  <div class=\"tips\" id=\"tightsTips\" aria-hidden=\"true\">\n    <strong>Съвети при измерване<\/strong>\n    <ul>\n      <li><strong>Височина:<\/strong> измерете без обувки, в сантиметри.<\/li>\n      <li><strong>Тегло:<\/strong> в килограми — използвайте приблизително ежедневното си тегло.<\/li>\n      <li>Ако сте между два размера, предпочитайте по-големия за повече комфорт. Някои модели са по-еластични и позволяват по-тесно прилягане.<\/li>\n    <\/ul>\n  <\/div>\n\n  <div class=\"grid\">\n    <div class=\"field\">\n      <label for=\"tightsHeight\">Височина (cm)<\/label>\n      <input id=\"tightsHeight\" type=\"number\" min=\"140\" step=\"0.5\" placeholder=\"напр. 170\">\n    <\/div>\n    <div class=\"field\">\n      <label for=\"tightsWeight\">Тегло (kg)<\/label>\n      <input id=\"tightsWeight\" type=\"number\" min=\"35\" step=\"0.1\" placeholder=\"напр. 62\">\n    <\/div>\n  <\/div>\n\n  <div class=\"actions\">\n    <button id=\"calcTights\">Изчисли размер<\/button>\n    <div id=\"clearTights\" style=\"cursor:pointer;color:#0073e6;text-decoration:underline;\">Изчисти<\/div>\n  <\/div>\n\n  <div id=\"tightsResult\" class=\"result\"><\/div>\n  <div id=\"tightsNote\" class=\"note\"><\/div>\n<\/div>\n\n<script>\n(function(){\n  var sizeTable = [\n    { name: \"IT 1 (XS)\", height:[145,160], weight:[40,50] },\n    { name: \"IT 2 (S)\",  height:[155,165], weight:[50,60] },\n    { name: \"IT 3 (M)\",  height:[160,170], weight:[60,70] },\n    { name: \"IT 4 (L)\",  height:[165,175], weight:[70,80] },\n    { name: \"IT 5 (XL)\", height:[170,185], weight:[80,95] }\n  ];\n\n  var elHeight = document.getElementById('tightsHeight');\n  var elWeight = document.getElementById('tightsWeight');\n  var btn = document.getElementById('calcTights');\n  var clr = document.getElementById('clearTights');\n  var out = document.getElementById('tightsResult');\n  var note = document.getElementById('tightsNote');\n\n  var tipsToggle = document.getElementById('toggleTightsTips');\n  var tipsBox = document.getElementById('tightsTips');\n  tipsToggle.addEventListener('click', function(){\n    var shown = tipsBox.style.display === 'block';\n    tipsBox.style.display = shown ? 'none' : 'block';\n    tipsBox.setAttribute('aria-hidden', shown ? 'true' : 'false');\n    tipsToggle.textContent = shown ? 'Съвети за измерване ▾' : 'Съвети за измерване ▴';\n  });\n\n  function inRange(v, r){ return v >= r[0] && v <= r[1]; }\n\n  function findExact(h, w){\n    var matches = [];\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      if(inRange(h, s.height) && inRange(w, s.weight)) matches.push(s);\n    }\n    return matches;\n  }\n\n  function closest(h, w){\n    var best = null, bestScore = Infinity;\n    for(var i=0;i<sizeTable.length;i++){\n      var s = sizeTable[i];\n      var midH = (s.height[0]+s.height[1])\/2;\n      var midW = (s.weight[0]+s.weight[1])\/2;\n      var score = Math.pow(h-midH,2) + Math.pow(w-midW,2);\n      if(score < bestScore){ bestScore = score; best = s; }\n    }\n    return best;\n  }\n\n  function formatRange(r){ return r[0] + \"–\" + r[1]; }\n\n  btn.addEventListener('click', function(){\n    out.style.display = 'none';\n    note.textContent = '';\n\n    var h = parseFloat(elHeight.value);\n    var w = parseFloat(elWeight.value);\n\n    if(isNaN(h) || isNaN(w) || h <= 0 || w <= 0){\n      out.style.display = 'block';\n      out.style.color = '#b00';\n      out.textContent = 'Моля въведете валидни стойности за височина (cm) и тегло (kg).';\n      return;\n    }\n\n    var exact = findExact(h, w);\n    if(exact.length > 0){\n      var s = exact[0];\n      out.style.display = 'block';\n      out.style.color = '#062';\n      out.textContent = 'Препоръчан размер: ' + s.name;\n      note.textContent = 'Диапазони за ' + s.name + ': височина ' + formatRange(s.height) + ' cm; тегло ' + formatRange(s.weight) + ' kg.';\n    } else {\n      var near = closest(h, w);\n      out.style.display = 'block';\n      out.style.color = '#e65d00';\n      out.textContent = 'Няма точен съвпад; най-близък размер: ' + near.name;\n      note.textContent = 'Диапазони: височина ' + formatRange(near.height) + ' cm; тегло ' + formatRange(near.weight) + ' kg. Ако предпочитате по-плътно прилягане, изберете по-малък; за повече комфорт — по-голям.';\n    }\n  });\n\n  clr.addEventListener('click', function(){\n    elHeight.value = '';\n    elWeight.value = '';\n    out.style.display = 'none';\n    note.textContent = '';\n  });\n\n  [elHeight, elWeight].forEach(function(el){\n    el.addEventListener('keydown', function(e){ if(e.key === 'Enter') btn.click(); });\n  });\n})();\n<\/script>"},"blocks":{}},"image_d8Lbwn":{"type":"image","name":"t:names.image","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/size-table-small.jpg","link":"","image_ratio":"adapt","width":"fill","custom_width":100,"width_mobile":"fill","custom_width_mobile":100,"height":"fit","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"accordion_XJ8UJt":{"type":"accordion","name":"t:names.accordion","settings":{"icon":"caret","dividers":true,"type_preset":"h6","inherit_color_scheme":true,"color_scheme":"","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"accordion_row_PPBBMU":{"type":"_accordion-row","settings":{"heading":"ДОСТАВКА И ПЛАЩАНЕ","open_by_default":false,"icon":"none","width":20},"blocks":{"text_P336YL":{"type":"text","settings":{"text":"<p>Разбираемо е, че стойността на доставката често тежи. <br\/>Ние предложихме гъвкави опции - вие избирате начин на доставка и плащате според услуга и общата стойност на поръчката.<\/p><p>За поръчки над 50 € (≈97.79 лв.) доставката е безплатна.<\/p><p>За поръчки под 50 € (≈97.79 лв.) таксите са:<\/p><ul><li>3.02 € (≈5.90 лв.) до офис на Еконт<\/li><li>3.53 € (≈6.90 лв.) до адрес<\/li><\/ul><p>Посочените цени важат за територията на цялата страна.<\/p>","width":"100%","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_P336YL"]},"accordion_row_Nmp8iR":{"type":"_accordion-row","settings":{"heading":"ВАЖНО","open_by_default":false,"icon":"none","width":24},"blocks":{"text_ENFf9p":{"type":"text","settings":{"text":"<p>Като вносители, ние подлагаме всяка дреха, която пристига при нас, на няколко щателни проверки за качество. За удобство и точност продуктите са допълнително оразмерени спрямо таблицата с размери, посочена в сайта. Обувките и аксесоарите също преминават строг контрол за качество при постъпване.<\/p><p>Препоръчителни инструкции за поддръжка на дрехи:<\/p><ul><li>Ръчно пране или пране на ниска температура (до 30°C).<\/li><li>Не използвайте сушилня за допълнителна обработка.<\/li><\/ul><p>Препоръчителни инструкции за поддръжка на обувки и аксесоари:<\/p><ul><li>Почистване на ръка; избягвайте силни почистващи препарати.<\/li><li>Не ператe в пералня и не оставяйте на пряка слънчева светлина.<\/li><\/ul><p>С всяка поръчка получавате гаранцията на Benny Boutique, че ще получите пратката си в перфектен вид, плюс:<\/p><ul><li>Бърза доставка<\/li><li>Тест и преглед преди изпращане<\/li><li>Безплатна доставка за поръчки над 50€ (≈97.79 лв)<\/li><li>Безплатна замяна за артикули на стойност над 35.79€ (≈70 лв)<\/li><\/ul>","width":"100%","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_ENFf9p"]},"accordion_row_kKD7ap":{"type":"_accordion-row","settings":{"heading":"ЧЕСТО ЗАДАВАНИ ВЪПРОСИ","open_by_default":false,"icon":"none","width":20},"blocks":{"text_wU8hYF":{"type":"text","settings":{"text":"<ol><li><strong>Как да поръчам?<\/strong><br\/>Можете да поръчате директно от сайта или по телефон на 0885905673.<\/li><li><strong>Мога ли да променя вече <\/strong>направена поръчка?<br\/>Да — ако поръчката не е изпратена още. Колкото по-скоро се свържете на 0885905673, толкова по-голяма е вероятността да успеем да направим промяната.<\/li><li><strong>Кога да очаквам пратката?<\/strong><br\/>Обикновено доставката отнема до два работни дни. Пратки до големи градове или до офис на куриер обикновено пристигат на следващия работен ден. Поръчки, направени след 13:00, се изпращат на следващия работен ден.<\/li><li><strong>Изпращате ли до офис на куриер?<\/strong><br\/>Да — работим с Еконт и можете да изберете доставка до техен офис при финализиране на поръчката.<\/li><li><strong>Мога ли да върна артикул?<\/strong><br\/>Върнете артикула чрез най-близкия офис на Еконт, придружен от попълнен формуляр за връщане. След получаване и обработка ще възстановим сумата по банков път (IBAN), в срок до 3 работни дни от датата на получаване. Връщането е за сметка на клиента, освен при дефект или при изпратен различен артикул\/размер\/цвят. Връщане в физически магазин не е възможно. Възстановяването се извършва единствено по банков път.<\/li><li><strong>Мога ли да заменя артикул?<\/strong><br\/>За замяна поръчайте желания артикул и ни върнете безплатно стоката, от която се отказвате. Колкото по-бързо го направите, толкова по-вероятно е да има наличности. Подробности има на страницата за връщания и замени.<\/li><li><strong>Как да избера правилния размер?<\/strong><br\/>Към всеки продукт е приложена таблица с размери. Ако имате въпроси, консултант може да ви помогне на 0885905673.<\/li><li><strong>Какво означава размер F?<\/strong><br\/>Размер F означава „свободен размер“ — моделът е създаден да пасва на диапазон от размери. Конкретният диапазон е посочен в описанието на продукта.<\/li><\/ol>","width":"100%","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_wU8hYF"]}},"block_order":["accordion_row_PPBBMU","accordion_row_Nmp8iR","accordion_row_kKD7ap"]}},"block_order":["group_icgrde","divider_VJhene","variant_picker_R3rGDr","buy_buttons_eYQEYi","text_aEtTtq","custom_liquid_9JjUCC","custom_liquid_bLUC7J","image_d8Lbwn","accordion_XJ8UJt"]}},"settings":{"content_width":"content-center-aligned","desktop_media_position":"left","equal_columns":false,"limit_details_width":false,"gap":48,"enable_sticky_add_to_cart":true,"color_scheme":"","padding-block-start":0,"padding-block-end":0}},"product_recommendations_qggXJq":{"type":"product-recommendations","blocks":{"text_cbcgyb":{"type":"text","name":"t:names.header","settings":{"text":"<h3>Може да харесате <\/h3>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"h4","font":"var(--font-primary--family)","font_size":"","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{