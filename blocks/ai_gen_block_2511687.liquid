{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
    position: relative;
    display: inline-block;
    animation: ai-glow-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  .ai-glow-heading__wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0%, 100% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
    }
    50% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity | times: 1.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 4.5 }}px {{ block.settings.glow_color }};
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-glow-heading__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading_tag == 'h1' %}
      <h1 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
    {% elsif block.settings.heading_tag == 'h2' %}
      <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
    {% elsif block.settings.heading_tag == 'h3' %}
      <h3 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
    {% elsif block.settings.heading_tag == 'h4' %}
      <h4 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
    {% elsif block.settings.heading_tag == 'h5' %}
      <h5 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
    {% else %}
      <h6 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Glowing heading",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#00ffff"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow intensity",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "s",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Glowing heading"
    }
  ]
}
{% endschema %}
