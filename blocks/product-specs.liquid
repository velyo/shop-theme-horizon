{% liquid
  assign product_resource = closest.product | default: product
  assign has_specs_text = product_resource.metafields.custom.specs_text
  assign has_choice_advices = product_resource.metafields.custom.choice_advices
  assign has_care_items = product_resource.metafields.custom.care_items
  assign has_materials = product_resource.metafields.custom.materials
  assign has_producer = product_resource.metafields.custom.producer
  assign has_country = product_resource.metafields.custom.country
%}

{% if product_resource and has_specs_text != blank or has_choice_advices != blank or has_care_items != blank or has_materials != blank or has_producer != blank or has_country != blank %}
  <div class="product-specs product-specs-{{ block.id }}" {{ block.shopify_attributes }}>
    {% if has_specs_text %}
      <h3 class="product-specs__title">{{ block.settings.specs_title }}</h3>
      <ul class="product-specs__list">
        {% assign text_values = product_resource.metafields.custom.specs_text | split: '"value":"' %}
        {% for value in text_values %}
          {% if forloop.index > 1 %}
            {% capture item %}{{ value | split: '"' | first }}{% endcapture %}
            {% if item != '' %}
              <li>{{ item }}</li>
            {% endif %}
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if has_choice_advices %}
      <h3 class="product-specs__title">{{ block.settings.choice_title }}</h3>
      <ul class="product-specs__list">
        {% assign text_values = product_resource.metafields.custom.choice_advices | split: '"value":"' %}
        {% for value in text_values %}
          {% if forloop.index > 1 %}
            {% capture item %}{{ value | split: '"' | first }}{% endcapture %}
            {% if item != '' %}
              <li>{{ item }}</li>
            {% endif %}
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if has_care_items %}
      <h3 class="product-specs__title">{{ block.settings.care_title }}</h3>
      <ul class="product-specs__list">
        {% assign text_values = product_resource.metafields.custom.care_items | split: '"value":"' %}
        {% for value in text_values %}
          {% if forloop.index > 1 %}
            {% capture item %}{{ value | split: '"' | first }}{% endcapture %}
            {% if item != '' %}
              <li>{{ item }}</li>
            {% endif %}
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    {% if has_materials %}
      <p class="product-specs__line"><strong>{{ block.settings.materials_title }}</strong> {{ product_resource.metafields.custom.materials | newline_to_br }}</p>
    {% endif %}

    {% if has_producer %}
      <p class="product-specs__line"><strong>{{ block.settings.producer_title }}</strong> {{ product_resource.metafields.custom.producer | newline_to_br }}</p>
    {% endif %}

    {% if has_country %}
      <p class="product-specs__line"><strong>{{ block.settings.country_title }}</strong> {{ product_resource.metafields.custom.country | newline_to_br }}</p>
    {% endif %}
  </div>

  <style>
    .product-specs-{{ block.id }} {
      margin-top: {{ block.settings.margin_top }}px;
      padding: 1rem;
      background-color: {{ block.settings.background_color }};
      border: 1px solid {{ block.settings.border_color }};
    }

    .product-specs-{{ block.id }} .product-specs__title {
      margin: 0.8rem 0 0.4rem;
      font-size: 1rem;
      line-height: 1.3;
    }

    .product-specs-{{ block.id }} .product-specs__list {
      margin: 0 0 0.8rem 1.2rem;
    }

    .product-specs-{{ block.id }} .product-specs__line {
      margin: 0.5rem 0;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Product specs",
  "settings": [
    {
      "type": "text",
      "id": "specs_title",
      "label": "Specs title",
      "default": "Характеристики:"
    },
    {
      "type": "text",
      "id": "choice_title",
      "label": "Choice advice title",
      "default": "Съвети за избор:"
    },
    {
      "type": "text",
      "id": "care_title",
      "label": "Care title",
      "default": "Съвети за поддръжка:"
    },
    {
      "type": "text",
      "id": "materials_title",
      "label": "Materials title",
      "default": "Състав:"
    },
    {
      "type": "text",
      "id": "producer_title",
      "label": "Producer title",
      "default": "Производител:"
    },
    {
      "type": "text",
      "id": "country_title",
      "label": "Country title",
      "default": "Страна:"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#dddddd"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin",
      "default": 16,
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px"
    }
  ]
}
{% endschema %}
